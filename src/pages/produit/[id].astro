---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import CartButton from '../../components/CartButton.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import productPageClientScript from '../../components/product-page-client.ts?url';
import { fetchProducts, activeProducts, getProductById } from '../../server/products';
import { formatPrice, buildWhatsAppUrl } from '../../utils';

export async function getStaticPaths() {
  const products = await fetchProducts();
  return activeProducts(products).map((product) => ({ params: { id: product.id } }));
}

const products = await fetchProducts();
const product = getProductById(products, Astro.params.id);

if (!product) {
  throw new Error(`Produit introuvable : ${Astro.params.id}`);
}

const whatsappPhone = import.meta.env.PUBLIC_WHATSAPP_PHONE || '22899769896';
const whatsappHref = buildWhatsAppUrl(whatsappPhone, [
  {
    id: product.id,
    name: product.name,
    price: product.price,
    image: product.image,
    quantity: 1,
  },
]);

const related = activeProducts(products).filter((item) => item.id !== product.id).slice(0, 3);
---
<Layout title={`Produit — ${product.name}`} description={product.description}>
  <Header>
    <CartButton slot="cart" />
  </Header>

  <main class="mx-auto max-w-7xl px-6 py-10 sm:px-8">
    <section class="grid gap-8 lg:grid-cols-[1.3fr_0.7fr] lg:items-start">
      <div class="space-y-6 rounded-3xl border border-white/10 bg-[#11131f] p-6 shadow-2xl shadow-black/20">
        <img
          src={product.image}
          alt={product.name}
          decoding="async"
          class="w-full rounded-3xl object-cover shadow-xl"
        />
        <div class="space-y-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
              <p class="text-sm uppercase tracking-[0.28em] text-[#ffd700]">{product.category}</p>
              <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">{product.name}</h1>
            </div>
            <span class="rounded-full bg-[#ffd700]/10 px-4 py-2 text-sm font-semibold text-[#ffd700] shadow-sm shadow-[#ffd700]/10">
              {formatPrice(product.price)}
            </span>
          </div>
          <p class="leading-relaxed text-gray-300">{product.description}</p>
          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-3xl bg-[#11131f] p-4 border border-white/5">
              <span class="block text-xs uppercase tracking-[0.2em] text-gray-400">Stock</span>
              <p class="mt-2 text-lg font-semibold text-white">{product.stock}</p>
            </div>
            <div class="rounded-3xl bg-[#11131f] p-4 border border-white/5">
              <span class="block text-xs uppercase tracking-[0.2em] text-gray-400">Référence</span>
              <p class="mt-2 text-lg font-semibold text-white">{product.id}</p>
            </div>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            <a
              href={whatsappHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center rounded-full bg-[#25d366] px-6 py-4 text-center text-sm font-bold uppercase tracking-[0.18em] text-[#0b2a13] shadow-lg shadow-[#25d366]/15 transition hover:bg-[#1ebe57]"
            >
              Commander ce produit sur WhatsApp
            </a>
            <button
              type="button"
              data-add-to-cart
              data-id={product.id}
              data-name={product.name}
              data-price={product.price}
              data-image={product.image}
              class="inline-flex w-full items-center justify-center rounded-full bg-[#e94560] px-6 py-4 text-center text-sm font-bold uppercase tracking-[0.18em] text-white shadow-lg shadow-[#ff5a77]/15 transition hover:bg-[#ff5a77]"
            >
              Ajouter au panier
            </button>
          </div>
          <a
            href="/"
            class="mt-4 inline-flex w-full items-center justify-center rounded-full border border-white/10 bg-white/5 px-6 py-4 text-center text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:border-[#ffd700] hover:bg-[#ffffff0f]"
          >
            Retour au catalogue
          </a>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="rounded-3xl border border-white/10 bg-[#11131f] p-6 shadow-2xl shadow-black/20">
          <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-[#ffd700]">Résumé rapide</h2>
          <ul class="mt-4 space-y-3 text-sm text-gray-300">
            <li>Catégorie : <span class="font-semibold text-white">{product.category}</span></li>
            <li>Disponibilité : <span class="font-semibold text-white">{product.stock > 0 ? 'En stock' : 'Épuisé'}</span></li>
            <li>Prix : <span class="font-semibold text-white">{formatPrice(product.price)}</span></li>
            <li>Statut : <span class="font-semibold text-white">Actif</span></li>
          </ul>
        </div>

        <div class="rounded-3xl border border-white/10 bg-[#11131f] p-6 shadow-2xl shadow-black/20">
          <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-300">Produits similaires</h3>
          <div class="mt-4 space-y-4">
            {related.map((item) => (
              <a
                class="block rounded-3xl border border-white/5 bg-[#0d101f] p-4 transition hover:border-[#ffd700]/40"
                href={`/produit/${item.id}`}
              >
                <h4 class="font-semibold text-white">{item.name}</h4>
                <p class="mt-2 text-sm text-gray-400">{formatPrice(item.price)}</p>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>

  <CartDrawer />
  <Footer />
  <script type="module" src={productPageClientScript}></script>
</Layout>
