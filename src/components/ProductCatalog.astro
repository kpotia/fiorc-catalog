---
import type { Product } from '../types';
import productCatalogClientScript from './product-catalog-client.ts?url';
const { products } = Astro.props as { products: Product[] };
const initialProducts = JSON.stringify(products);
const categories: string[] = ['Toutes catégories', ...new Set(products.map((product) => product.category))];
---
<section id="catalogue" class="py-10" data-catalog data-products={initialProducts}>
  <div class="mx-auto max-w-7xl rounded-[2rem] border border-white/10 bg-[#11131f]/90 px-6 py-8 shadow-2xl shadow-black/40 sm:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-3">
        <p class="text-sm uppercase tracking-[0.24em] text-[#ffd700]">Catalogue interactif</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Trouvez le produit parfait</h2>
        <p class="max-w-2xl text-sm leading-relaxed text-gray-400">
          Filtrez, recherchez et commandez depuis un seul catalogue sans charger un client complet dès le départ.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:max-w-xs">
        <div class="relative">
          <span class="pointer-events-none absolute left-4 top-3.5 text-gray-400">🔍</span>
          <input
            type="text"
            data-catalog-search
            placeholder="Rechercher un produit..."
            class="w-full rounded-2xl border border-white/10 bg-[#0d101f] py-3 pl-12 pr-4 text-sm text-white outline-none transition focus:border-[#e94560]"
          />
        </div>

        <button
          type="button"
          data-catalog-reset
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/10 bg-[#161a2f] px-5 py-3 text-sm font-semibold text-white transition hover:border-[#ffd700]"
        >
          ✕ Réinitialiser
        </button>
      </div>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-[minmax(260px,320px)_1fr]">
      <div class="space-y-4 rounded-3xl border border-white/10 bg-[#0c0f1a] p-6 shadow-inner shadow-black/30">
        <div class="space-y-4">
          <label class="block text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Catégorie</label>
          <select
            data-catalog-category
            class="w-full rounded-2xl border border-white/10 bg-[#11131f] py-3 px-4 text-sm text-white outline-none transition focus:border-[#e94560]"
          >
            {categories.map((category) => (
              <option value={category}>{category}</option>
            ))}
          </select>
        </div>

        <div class="space-y-4">
          <label class="block text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Trier par</label>
          <select
            data-catalog-sort
            class="w-full rounded-2xl border border-white/10 bg-[#11131f] py-3 px-4 text-sm text-white outline-none transition focus:border-[#e94560]"
          >
            <option value="featured">Par défaut</option>
            <option value="price-asc">Prix : croissant</option>
            <option value="price-desc">Prix : décroissant</option>
            <option value="newest">Nouveautés</option>
          </select>
        </div>

        <div class="rounded-3xl border border-white/10 bg-[#11131f] p-5 text-sm text-gray-400">
          <p class="font-semibold text-white">Produits affichés</p>
          <p class="mt-3" data-catalog-count>{products.length} / {products.length}</p>
          <p class="mt-3 text-xs leading-relaxed text-gray-500">
            Les produits sont chargés côté serveur et hydratés ensuite uniquement quand le catalogue apparaît à l'écran.
          </p>
        </div>
      </div>

      <div class="space-y-6">
        <div data-catalog-items class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {products.map((product) => (
            <article class="overflow-hidden rounded-[2rem] border border-white/10 bg-[#11131f] shadow-lg shadow-black/20 transition hover:-translate-y-1">
              <img
                src={product.image}
                alt={product.name}
                decoding="async"
                class="h-48 w-full object-cover"
              />
              <div class="p-4">
                <div class="flex items-center justify-between gap-2">
                  <p class="text-xs uppercase tracking-[0.18em] text-[#ffd700]">{product.category}</p>
                  <span class="text-xs text-gray-400">{product.stock} en stock</span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-white">{product.name}</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-400 line-clamp-2">{product.description}</p>
                <div class="mt-5 flex items-center justify-between gap-3">
                  <span class="text-base font-bold text-[#ffd700]">{product.price.toLocaleString('fr-FR')} FCFA</span>
                  <div class="flex items-center gap-2">
                    <a
                      href={`/produit/${product.id}`}
                      class="rounded-full bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.18em] text-white transition hover:bg-[#ffd700]/15"
                    >Voir</a>
                    <button
                      type="button"
                      data-add-to-cart
                      data-id={product.id}
                      data-name={product.name}
                      data-price={product.price}
                      data-image={product.image}
                      class="rounded-full bg-[#e94560] px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-[#ff5a77]"
                    >Ajouter</button>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div data-catalog-empty class="hidden rounded-[2rem] border border-dashed border-gray-800 bg-[#1a1a2e]/30 p-12 text-center text-gray-300">
          <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-gray-900 text-gray-500">👀</div>
          <h3 class="text-xl font-semibold text-white">Aucun produit ne correspond</h3>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-gray-400">
            Essayez de modifier vos filtres ou effectuez une autre recherche pour trouver ce que vous cherchez.
          </p>
          <button
            type="button"
            data-catalog-reset
            class="mt-6 rounded-full bg-[#e94560] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#ff5a77]"
          >
            Afficher tous les produits
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module" src={productCatalogClientScript}></script>
