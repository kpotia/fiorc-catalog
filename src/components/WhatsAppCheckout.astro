---
const { phoneNumber } = Astro.props;
---
<a
  href="#"
  data-whatsapp-checkout
  class="inline-flex w-full items-center justify-between gap-3 rounded-3xl px-5 py-4 text-sm font-semibold uppercase tracking-[0.16em] transition bg-[#0f101d] text-gray-500 border border-white/10"
  target="_blank"
  rel="noopener noreferrer"
  aria-disabled="true"
>
  <span>Commander sur WhatsApp</span>
  <span data-whatsapp-total class="text-xs font-semibold text-[#07210f]">0 FCFA</span>
</a>
