---
import WhatsAppCheckout from './WhatsAppCheckout.astro';
import CartClientLoader from './CartClientLoader.tsx';
---
<div data-cart-drawer class="fixed inset-0 z-50 overflow-hidden transition-all duration-300 invisible pointer-events-none" aria-labelledby="slide-over-title" role="dialog" aria-modal="true">
  <div
    data-cart-overlay
    class="absolute inset-0 bg-black/75 backdrop-blur-sm opacity-0 transition-opacity duration-300"
  ></div>

  <div class="absolute inset-y-0 right-0 flex max-w-full pl-10">
    <div class="w-screen max-w-md transform bg-[#1a1a2e] border-l border-white/10 text-white shadow-2xl transition-transform duration-300 ease-in-out translate-x-full">
      <div class="flex h-full flex-col justify-between">
        <div class="flex items-center justify-between border-b border-white/10 px-4 py-6 sm:px-6">
          <div class="flex items-center gap-2">
            <span class="text-[#ffd700] text-lg">🛒</span>
            <h2 class="text-lg font-bold text-white" id="slide-over-title">Mon Panier</h2>
          </div>
          <button
            type="button"
            data-cart-close
            class="rounded-lg border border-white/10 p-1.5 text-gray-400 hover:bg-[#16213e] hover:text-white transition-all"
          >
            ✕
          </button>
        </div>

        <div class="flex-1 overflow-y-auto px-4 py-6 sm:px-6 scrollbar-thin">
          <div data-cart-empty class="flex h-full flex-col items-center justify-center gap-6 text-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-[#e94560]/10 text-[#e94560]">
              <span class="text-4xl">🛒</span>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Votre panier est vide</h3>
              <p class="mt-2 text-sm text-gray-400">
                Ajoutez des produits au panier pour préparer votre commande WhatsApp.
              </p>
            </div>
            <button
              type="button"
              data-cart-close
              class="inline-flex items-center gap-2 rounded-full bg-gray-800 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-gray-700"
            >
              Retour au catalogue →
            </button>
          </div>

          <div data-cart-items class="space-y-4 hidden"></div>
        </div>

        <div data-cart-summary class="space-y-4 border-t border-white/10 bg-[#0f101d] p-6 hidden">
          <div class="flex items-center justify-between text-sm text-gray-400">
            <span>Articles</span>
            <span data-cart-count-summary>0</span>
          </div>
          <div class="flex items-center justify-between border-t border-white/10 pt-4 text-base font-semibold text-white">
            <span>Total estimé</span>
            <span data-cart-total>0 FCFA</span>
          </div>
          <WhatsAppCheckout phoneNumber={import.meta.env.PUBLIC_WHATSAPP_PHONE || '22899769896'} />
          <button
            type="button"
            data-cart-clear
            class="w-full rounded-3xl border border-white/10 bg-[#11131f] py-3 text-sm font-semibold uppercase tracking-[0.16em] text-gray-400 transition hover:border-[#ffd700] hover:text-white"
          >
            Vider le panier
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<CartClientLoader client:load />
